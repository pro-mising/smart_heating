","file":"HeroSection.vue","sourceRoot":"src/components","sourcesContent":["<template>\r\n  <div class=\"hero-section\">\r\n    <h1 class=\"hero-title\">智能供暖控制平台</h1>\r\n    <p class=\"hero-subtitle\">基于AI算法的智慧供暖管理系统，实时监控、精准预测、智能控制，提升供暖效率1000%</p>\r\n    \r\n    <div class=\"action-buttons\">\r\n      <ActionButton\r\n        v-for=\"button in buttons\"\r\n        :key=\"button.type\"\r\n        :type=\"button.type\"\r\n        :title=\"button.title\"\r\n        :description=\"button.description\"\r\n        :icon=\"button.icon\"\r\n        @click=\"handleButtonClick\"\r\n      />\r\n    </div>\r\n    \r\n    <div class=\"tech-decoration\">\r\n      <div class=\"circle circle-1\"></div>\r\n      <div class=\"circle circle-2\"></div>\r\n      <div class=\"pulse-dot\"></div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport ActionButton from './ActionButton.vue'\r\n\r\nexport default {\r\n  name: 'HeroSection',\r\n  components: {\r\n    ActionButton\r\n  },\r\n  data() {\r\n    return {\r\n      buttons: [\r\n        { type: 'monitor', title: '数据监控', description: '实时监测供暖系统运行状态', icon: 'fa-chart-line' },\r\n        { type: 'predict', title: '数据预测', description: '基于AI预测供暖需求变化', icon: 'fa-brain' },\r\n        { type: 'control', title: '控制系统', description: '远程智能调控供暖参数', icon: 'fa-sliders-h' },\r\n        { type: 'user', title: '用户中心', description: '个性化设置与系统管理', icon: 'fa-user-cog' }\r\n      ]\r\n    }\r\n  },\r\n  methods: {\r\n    handleButtonClick(type) {\r\n      this.$emit('button-click', type)\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/*智能供暖主视觉区域*/\r\n.hero-section {\r\n  position: relative;\r\n  padding: 80px 20px;\r\n  margin: 0 auto;\r\n  max-width: 1200px;\r\n  border-radius: 15px;\r\n  overflow: hidden;\r\n  \r\n  background: \r\n    linear-gradient(135deg, #0a192f 0%, #020c1b 100%),\r\n    repeating-linear-gradient(\r\n      45deg,\r\n      rgba(100, 255, 218, 0.05) 0px,\r\n      rgba(100, 255, 218, 0.05) 1px,\r\n      transparent 1px,\r\n      transparent 10px\r\n    );\r\n  \r\n  /* 边框光效 */\r\n  box-shadow: \r\n    0 0 0 1px rgba(100, 255, 218, 0.1),\r\n    0 10px 30px rgba(0, 0, 0, 0.5);\r\n}\r\n\r\n/* 主标题 */\r\n.hero-title {\r\n  color: white;\r\n  font-size: 3rem;\r\n  font-weight: 700;\r\n  margin-bottom: 20px;\r\n  position: relative;\r\n  z-index: 2;\r\n  text-align: center;\r\n  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);\r\n}\r\n\r\n/* 副标题 */\r\n.hero-subtitle {\r\n  color: rgba(255, 255, 255, 0.85);\r\n  font-size: 1.2rem;\r\n  max-width: 700px;\r\n  margin: 0 auto 50px;\r\n  line-height: 1.6;\r\n  position: relative;\r\n  z-index: 2;\r\n}\r\n\r\n/* 按钮容器 */\r\n.action-buttons {\r\n  display: grid;\r\n  grid-template-columns: repeat(2, 1fr);\r\n  gap: 30px;\r\n  max-width: 900px;\r\n  margin: 0 auto;\r\n  position: relative;\r\n  z-index: 2;\r\n}\r\n\r\n.tech-decoration {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  overflow: hidden;\r\n  z-index: 1;\r\n}\r\n\r\n.circle {\r\n  position: absolute;\r\n  border-radius: 50%;\r\n  background: rgba(100, 255, 218, 0.1);\r\n  border: 1px solid rgba(100, 255, 218, 0.2);\r\n}\r\n\r\n.circle-1 {\r\n  width: 300px;\r\n  height: 300px;\r\n  top: -100px;\r\n  right: -100px;\r\n}\r\n\r\n.circle-2 {\r\n  width: 150px;\r\n  height: 150px;\r\n  bottom: -50px;\r\n  left: -50px;\r\n}\r\n\r\n.pulse-dot {\r\n  position: absolute;\r\n  width: 10px;\r\n  height: 10px;\r\n  background: #64ffda;\r\n  border-radius: 50%;\r\n  top: 30%;\r\n  left: 20%;\r\n  animation: pulse 3s infinite;\r\n  box-shadow: 0 0 0 0 rgba(100, 255, 218, 0.7);\r\n}\r\n\r\n@keyframes pulse {\r\n  0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(100, 255, 218, 0.7); }\r\n  70% { transform: scale(1.2); box-shadow: 0 0 0 15px rgba(100, 255, 218, 0); }\r\n  100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(100, 255, 218, 0); }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .hero-title {\r\n    font-size: 2.2rem;\r\n  }\r\n  \r\n  .hero-subtitle {\r\n    font-size: 1rem;\r\n    padding: 0 20px;\r\n  }\r\n  \r\n  .action-buttons {\r\n    grid-template-columns: 1fr;\r\n  }\r\n}\r\n</style>"]}]}