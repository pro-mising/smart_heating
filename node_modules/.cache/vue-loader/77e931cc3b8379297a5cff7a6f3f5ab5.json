mport NavBar from './components/NavBar.vue'\r\nimport HeroSection from './components/HeroSection.vue'\r\n\r\nexport default {\r\n  name: 'App',\r\n  components: {\r\n    NavBar,\r\n    HeroSection\r\n  },\r\n  methods: {\r\n    handleButtonClick(buttonType) {\r\n      console.log(`进入${buttonType}模块`)\r\n      switch (buttonType) {\r\n        case 'monitor':\r\n      this.$router.push('/monitor')\r\n      break\r\n    }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style>\r\n/* ===== 智能供暖系统全局样式 ===== */\r\n/* 1. 深色主题背景 */\r\n#app {\r\n  background: linear-gradient(\r\n    135deg, \r\n    #26354a 0%,    \r\n    #0c3065 100%    \r\n  );\r\n  min-height: 100vh;\r\n  color: #ccd6f6;   \r\n}\r\n\r\n/* 2. 主内容区域 */\r\n.main-content {\r\n  padding-top: 100px;\r\n  text-align: center;\r\n}\r\n\r\n/* 3. 大标题样式 */\r\n.hero-title {\r\n  color: white !important;\r\n  font-size: 3.2rem;\r\n  font-weight: 700;\r\n  letter-spacing: 1.5px;\r\n  margin-bottom: 20px;\r\n  text-shadow: \r\n    0 0 10px rgba(100, 255, 218, 0.3),\r\n    0 2px 15px rgba(0, 0, 0, 0.5);\r\n}\r\n\r\n/* 4. 副标题样式 */\r\n.hero-subtitle {\r\n  color: rgba(255, 255, 255, 0.85) !important;\r\n  font-size: 1.2rem;\r\n  max-width: 700px;\r\n  margin: 0 auto 40px;\r\n  line-height: 1.6;\r\n}\r\n\r\n/* 5. 导航栏适配 */\r\n.navbar {\r\n  background-color: rgba(10, 25, 47, 0.95) !important;\r\n  backdrop-filter: blur(5px);\r\n}\r\n\r\n/* 6. 操作按钮悬浮效果 */\r\n.action-btn:hover {\r\n  transform: translateY(-5px) scale(1.02);\r\n  box-shadow: 0 8px 25px rgba(0, 118, 255, 0.3) !important;\r\n}\r\n\r\n/* 7. 温度计特殊样式 */\r\n.temperature-display {\r\n  background: rgba(16, 42, 87, 0.6);\r\n  border: 1px solid #1f3a68;\r\n  border-radius: 12px;\r\n}\r\n\r\n/* 响应式调整 */\r\n@media (max-width: 768px) {\r\n  .hero-title {\r\n    font-size: 2.5rem;\r\n  }\r\n  \r\n  .hero-subtitle {\r\n    font-size: 1rem;\r\n    padding: 0 20px;\r\n  }\r\n}\r\n</style>"]}]}