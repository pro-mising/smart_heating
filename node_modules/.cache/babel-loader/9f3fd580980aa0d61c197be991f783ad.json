warning\" \r\n        class=\"el-icon-warning warning-icon\"\r\n      ></i>\r\n    </span>\r\n    <div \r\n      class=\"temp-bar\"\r\n      :style=\"barStyle\"\r\n    ></div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'TempIndicator',\r\n  props: {\r\n    value: {\r\n      type: [Number, String],\r\n      required: true\r\n    },\r\n    type: {\r\n      type: String,\r\n      validator: v => ['outdoor', 'indoor', 'supply'].includes(v),\r\n      default: 'indoor'\r\n    },\r\n    warning: {\r\n      type: Boolean,\r\n      default: false\r\n    }\r\n  },\r\n  computed: {\r\n    normalizedValue() {\r\n      const temp = parseFloat(this.value)\r\n      if (this.type === 'outdoor') {\r\n        // 室外温度范围：-20℃ ~ 40℃\r\n        return Math.min(40, Math.max(-20, temp))\r\n      } else if (this.type === 'supply') {\r\n        // 供温范围：50℃ ~ 90℃\r\n        return Math.min(90, Math.max(50, temp))\r\n      }\r\n      // 室温范围：10℃ ~ 30℃\r\n      return Math.min(30, Math.max(10, temp))\r\n    },\r\n    tempClass() {\r\n      const temp = parseFloat(this.value)\r\n      if (this.type === 'outdoor') {\r\n        return temp < -5 ? 'low' : temp > 30 ? 'high' : ''\r\n      } else if (this.type === 'supply') {\r\n        return temp > 75 ? 'high' : temp < 60 ? 'low' : ''\r\n      }\r\n      return temp < 16 ? 'low' : temp > 24 ? 'high' : ''\r\n    },\r\n    tempStyle() {\r\n      if (this.warning) {\r\n        return { color: '#ff6b35' }\r\n      }\r\n      return {}\r\n    },\r\n    barStyle() {\r\n      let percentage, background\r\n      const temp = this.normalizedValue\r\n      \r\n      if (this.type === 'outdoor') {\r\n        percentage = ((temp + 20) / 60) * 100\r\n        background = 'linear-gradient(90deg, #00d4ff, #ff6b35)'\r\n      } else if (this.type === 'supply') {\r\n        percentage = ((temp - 50) / 40) * 100\r\n        background = 'linear-gradient(90deg, #4cb944, #ff6b35)'\r\n      } else {\r\n        percentage = ((temp - 10) / 20) * 100\r\n        background = 'linear-gradient(90deg, #00d4ff, #ff6b35)'\r\n      }\r\n      \r\n      return {\r\n        width: `${Math.min(100, Math.max(0, percentage))}%`,\r\n        background\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.temp-indicator {\r\n  display: flex;\r\n  flex-direction: column;\r\n  width: 100%;\r\n}\r\n\r\n.temp-value {\r\n  font-family: 'Courier New', monospace;\r\n  font-weight: bold;\r\n  margin-bottom: 4px;\r\n}\r\n\r\n.temp-value.low {\r\n  color: #00d4ff;\r\n}\r\n\r\n.temp-value.high {\r\n  color: #ff6b35;\r\n}\r\n\r\n.warning-icon {\r\n  margin-left: 4px;\r\n}\r\n\r\n.temp-bar {\r\n  height: 4px;\r\n  border-radius: 2px;\r\n  transition: width 0.5s ease;\r\n}\r\n\r\n::v-deep .el-tooltip__popper {\r\n  background: #112240 !important;\r\n  border: 1px solid #1f3a68 !important;\r\n}\r\n</style>"],"mappings":"AAqBA;EACAA,IAAA;EACAC,KAAA;IACAC,KAAA;MACAC,IAAA,GAAAC,MAAA,EAAAC,MAAA;MACAC,QAAA;IACA;IACAH,IAAA;MACAA,IAAA,EAAAE,MAAA;MACAE,SAAA,EAAAC,CAAA,oCAAAC,QAAA,CAAAD,CAAA;MACAE,OAAA;IACA;IACAC,OAAA;MACAR,IAAA,EAAAS,OAAA;MACAF,OAAA;IACA;EACA;EACAG,QAAA;IACAC,gBAAA;MACA,MAAAC,IAAA,GAAAC,UAAA,MAAAd,KAAA;MACA,SAAAC,IAAA;QACA;QACA,OAAAc,IAAA,CAAAC,GAAA,KAAAD,IAAA,CAAAE,GAAA,MAAAJ,IAAA;MACA,gBAAAZ,IAAA;QACA;QACA,OAAAc,IAAA,CAAAC,GAAA,KAAAD,IAAA,CAAAE,GAAA,KAAAJ,IAAA;MACA;MACA;MACA,OAAAE,IAAA,CAAAC,GAAA,KAAAD,IAAA,CAAAE,GAAA,KAAAJ,IAAA;IACA;IACAK,UAAA;MACA,MAAAL,IAAA,GAAAC,UAAA,MAAAd,KAAA;MACA,SAAAC,IAAA;QACA,OAAAY,IAAA,gBAAAA,IAAA;MACA,gBAAAZ,IAAA;QACA,OAAAY,IAAA,iBAAAA,IAAA;MACA;MACA,OAAAA,IAAA,gBAAAA,IAAA;IACA;IACAM,UAAA;MACA,SAAAV,OAAA;QACA;UAAAW,KAAA;QAAA;MACA;MACA;IACA;IACAC,SAAA;MACA,IAAAC,UAAA,EAAAC,UAAA;MACA,MAAAV,IAAA,QAAAD,eAAA;MAEA,SAAAX,IAAA;QACAqB,UAAA,IAAAT,IAAA;QACAU,UAAA;MACA,gBAAAtB,IAAA;QACAqB,UAAA,IAAAT,IAAA;QACAU,UAAA;MACA;QACAD,UAAA,IAAAT,IAAA;QACAU,UAAA;MACA;MAEA;QACAC,KAAA,KAAAT,IAAA,CAAAC,GAAA,MAAAD,IAAA,CAAAE,GAAA,IAAAK,UAAA;QACAC;MACA;IACA;EACA;AACA","ignoreList":[]}]}