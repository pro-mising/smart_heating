   </span>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'HumidityIndicator',\r\n  props: {\r\n    value: {\r\n      type: [Number, String],\r\n      required: true\r\n    }\r\n  },\r\n  computed: {\r\n    normalizedValue() {\r\n      const humidity = parseFloat(this.value)\r\n      return Math.min(100, Math.max(0, humidity))\r\n    },\r\n    isWarning() {\r\n      const humidity = parseFloat(this.value)\r\n      return humidity > 70 || humidity < 30\r\n    },\r\n    humidityColor() {\r\n      const humidity = parseFloat(this.value)\r\n      if (humidity > 70) return '#ff6b35'\r\n      if (humidity < 30) return '#00d4ff'\r\n      return '#4cb944'\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.humidity-indicator {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.humidity-value {\r\n  margin-left: 8px;\r\n  font-family: 'Courier New', monospace;\r\n  font-weight: bold;\r\n}\r\n\r\n.warning-icon {\r\n  margin-left: 4px;\r\n  color: #ff6b35;\r\n}\r\n\r\n::v-deep .el-progress-bar {\r\n  width: 60px;\r\n}\r\n\r\n::v-deep .el-progress-bar__outer {\r\n  background-color: rgba(255, 255, 255, 0.1);\r\n  border-radius: 4px;\r\n}\r\n</style>"],"mappings":"AAUA;EACAA,IAAA;EACAC,KAAA;IACAC,KAAA;MACAC,IAAA,GAAAC,MAAA,EAAAC,MAAA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACAC,gBAAA;MACA,MAAAC,QAAA,GAAAC,UAAA,MAAAR,KAAA;MACA,OAAAS,IAAA,CAAAC,GAAA,MAAAD,IAAA,CAAAE,GAAA,IAAAJ,QAAA;IACA;IACAK,UAAA;MACA,MAAAL,QAAA,GAAAC,UAAA,MAAAR,KAAA;MACA,OAAAO,QAAA,SAAAA,QAAA;IACA;IACAM,cAAA;MACA,MAAAN,QAAA,GAAAC,UAAA,MAAAR,KAAA;MACA,IAAAO,QAAA;MACA,IAAAA,QAAA;MACA;IACA;EACA;AACA","ignoreList":[]}]}